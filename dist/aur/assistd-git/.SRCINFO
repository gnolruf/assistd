pkgbase = assistd-git
	pkgdesc = A local-model agent daemon for Linux (LLM + voice + tools + WM integration) - git HEAD
	pkgver = 1.0.0.r246.g9199320
	pkgrel = 1
	url = https://github.com/gnolruf/assistd
	install = assistd.install
	arch = x86_64
	license = Apache-2.0
	makedepends = rust
	makedepends = cmake
	makedepends = clang
	makedepends = pkgconf
	makedepends = git
	depends = alsa-lib
	depends = dbus
	optdepends = llama.cpp: provides llama-server (required to run a local LLM backend)
	optdepends = piper-tts: Piper text-to-speech voice output
	optdepends = maim: X11 full/region screenshot capture
	optdepends = slop: maim --select region picker
	optdepends = grim: Wayland full/region screenshot capture
	optdepends = xdotool: X11 focused-window screenshot
	optdepends = xorg-xrandr: X11 multi-monitor info for screenshots
	optdepends = sway: Wayland focused-window screenshot via swaymsg
	optdepends = hyprland: Wayland focused-window screenshot via hyprctl
	optdepends = bubblewrap: sandboxed bash command tool
	optdepends = pipewire-pulse: PulseAudio routing for audio playback (otherwise raw ALSA)
	optdepends = libxkbcommon: tray-popup GUI (dlopened at runtime)
	optdepends = libxcb: tray-popup GUI on X11 (dlopened at runtime)
	optdepends = wayland: tray-popup GUI on Wayland (dlopened at runtime)
	optdepends = libglvnd: tray-popup GUI OpenGL renderer (dlopened at runtime)
	optdepends = fontconfig: tray-popup GUI text rendering (dlopened at runtime)
	provides = assistd=1.0.0.r246.g9199320
	conflicts = assistd
	options = !lto
	backup = etc/assistd/config.toml
	source = assistd::git+https://github.com/gnolruf/assistd.git
	sha256sums = SKIP

pkgname = assistd-git
